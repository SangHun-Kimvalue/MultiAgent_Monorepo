{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multiagent-methodology.local/schemas/review-verdict.schema.json",
  "title": "Independent implementation review verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewed_at_utc",
    "executor",
    "reviewer",
    "independence_mode",
    "fallback_level",
    "review_base_sha",
    "reviewed_paths",
    "command_shape",
    "review_artifact_path",
    "raw_output_path",
    "verdict",
    "exit_code",
    "findings",
    "dispositions"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "reviewed_at_utc": {"type": "string", "format": "date-time"},
    "executor": {"$ref": "#/$defs/actor"},
    "reviewer": {"$ref": "#/$defs/actor"},
    "independence_mode": {
      "enum": ["cross-lineage-cli", "cross-lineage-session", "same-lineage-degraded"]
    },
    "fallback_level": {"type": "integer", "minimum": 1, "maximum": 3},
    "degraded_reason": {"type": "string", "minLength": 1},
    "review_base_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "reviewed_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "command_shape": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "review_artifact_path": {"type": "string", "minLength": 1},
    "raw_output_path": {"type": "string", "minLength": 1},
    "verdict": {"enum": ["PASS", "CHANGES_REQUESTED", "BLOCKED"]},
    "exit_code": {"type": "integer"},
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"}
    },
    "dispositions": {
      "type": "array",
      "items": {"$ref": "#/$defs/disposition"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"independence_mode": {"const": "cross-lineage-cli"}}},
      "then": {"properties": {"fallback_level": {"const": 1}}}
    },
    {
      "if": {"properties": {"independence_mode": {"const": "cross-lineage-session"}}},
      "then": {"properties": {"fallback_level": {"const": 2}}}
    },
    {
      "if": {"properties": {"independence_mode": {"const": "same-lineage-degraded"}}},
      "then": {
        "required": ["degraded_reason"],
        "properties": {"fallback_level": {"const": 3}}
      }
    },
    {
      "if": {"properties": {"verdict": {"const": "PASS"}}},
      "then": {"properties": {"exit_code": {"const": 0}}}
    }
  ],
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "cli_version", "lineage", "model", "session_id"],
      "properties": {
        "tool": {"type": "string", "minLength": 1},
        "cli_version": {"type": "string", "minLength": 1},
        "lineage": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "session_id": {"type": "string", "minLength": 1}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "finding", "evidence_or_repro", "impact", "recommendation"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "severity": {"enum": ["P0", "P1", "P2", "P3"]},
        "finding": {"type": "string", "minLength": 1},
        "evidence_or_repro": {"type": "string", "minLength": 1},
        "impact": {"type": "string", "minLength": 1},
        "recommendation": {"type": "string", "minLength": 1}
      }
    },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "status", "evidence", "rationale"],
      "properties": {
        "finding_id": {"type": "string", "minLength": 1},
        "status": {
          "enum": ["ACCEPT", "REJECT_FALSE_POSITIVE", "DEFER_OUT_OF_SCOPE", "REJECT_OVERENGINEERING"]
        },
        "evidence": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1}
      }
    }
  }
}
